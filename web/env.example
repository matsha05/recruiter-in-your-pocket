# Frontend base URL (used for Stripe success/cancel redirects)
# Local: http://localhost:3000
NEXT_PUBLIC_APP_URL=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_BUCKET=resumes
NEXT_PUBLIC_MIXPANEL_TOKEN=
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_BILLING_UNLOCK=true
NEXT_PUBLIC_ENABLE_EXTENSION_SYNC=false
NEXT_PUBLIC_ENABLE_GUEST_REPORT_SAVE=false
NEXT_PUBLIC_ENABLE_PUBLIC_SHARE_LINKS=false
NEXT_PUBLIC_ENABLE_ERROR_REPLAY=false

# --- Server-only (Route Handlers / Webhooks) ---
# Used to sign the free-run cookie. Any long random string.
SESSION_SECRET=

# OpenAI for resume analysis (server-only)
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_TIMEOUT_MS=60000
# OPENAI_MAX_RETRIES=1
# OPENAI_RETRY_BACKOFF_MS=300

# Stripe (server-only)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_LIFETIME=
STRIPE_PRICE_ID_24H=
STRIPE_PRICE_ID_30D=
# Legacy fallback if you only have one price:
# STRIPE_PRICE_ID=

# Supabase admin key for Stripe webhook writes (server-only)
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated exact extension origins, e.g.
# RIYP_EXTENSION_ORIGINS=chrome-extension://abcdefghijklmnopqrstuvwxyzabcdef
# Keep NEXT_PUBLIC_ENABLE_EXTENSION_SYNC=false until this is set.
RIYP_EXTENSION_ORIGINS=

# Optional toggles
# BYPASS_PAYWALL=true
# USE_SPARTICUZ_CHROMIUM=true
